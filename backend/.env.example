# ─── Base de datos (Supabase) ────────────────────────────────────────────────
# Copia estos valores desde: Supabase → Settings → Database → Connection String

# "Transaction" pooler URL (para la app en producción) — obligatorio
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# "Session" / Direct URL (para migraciones de Prisma) — obligatorio para `prisma migrate`
# PgBouncer en modo transaction no soporta DDL, por eso las migraciones usan la URL directa.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Genera una clave aleatoria de al menos 32 chars: `openssl rand -hex 32`
JWT_SECRET="cambiar-por-una-clave-de-al-menos-32-caracteres-generada-aleatoriamente"
JWT_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Allowlist de orígenes permitidos por CORS. Lista separada por comas.
# OBLIGATORIO en producción (el bootstrap del backend tira un Error si NODE_ENV=production y falta).
# En desarrollo es opcional — el backend acepta localhost y rangos LAN privados automáticamente.
# FRONTEND_URL="https://tu-app.vercel.app,https://otro-dominio.com"

# ─── IA (LLM provider) ───────────────────────────────────────────────────────
# El AiService exige al menos uno de AI_API_KEY u OPENAI_API_KEY al arrancar.
# AI_API_KEY es el nombre preferido (funciona con OpenAI, OpenRouter o cualquier provider compatible).
AI_API_KEY="sk-..."
# OPENAI_API_KEY="sk-..."             # alias legacy, ambos son aceptados

# Base URL del provider. Default: https://api.openai.com/v1
# AI_API_URL="https://openrouter.ai/api/v1"

# Modelo a usar. Default: z-ai/glm-4.5-air:free (gratuito vía OpenRouter)
# AI_MODEL="gpt-4o-mini"

# ─── Redis (opcional) ────────────────────────────────────────────────────────
# Si está presente, el AiService persiste el borrador de preguntas generadas
# durante 30 min entre POST /ai/generate-questions y POST /ai/save-questions.
# Si falta, la app sigue funcionando — solo se pierden los borradores si el
# navegador se cierra antes de guardar.
# REDIS_URL="redis://default:password@host:6379"
